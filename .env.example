# ===== ANNADANAM OTP SERVICE CONFIGURATION =====
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# ===== TWILIO CONFIGURATION (SMS) =====
# Sign up at: https://www.twilio.com/
# Free trial: $15 credit, can send to verified numbers
# Production: Pay-as-you-go, ~$0.0075 per SMS in India

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ===== SENDGRID CONFIGURATION (EMAIL) =====
# Sign up at: https://sendgrid.com/
# Free tier: 100 emails/day forever
# Production: 40,000 emails/month for $14.95

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@annadanam.org
SENDGRID_FROM_NAME=Annadanam Food Charity

# ===== ALTERNATIVE SMS PROVIDERS =====

# MSG91 (India-focused, cheaper for Indian numbers)
# Sign up at: https://msg91.com/
# Pricing: ~₹0.15 per SMS in India
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_SENDER_ID=ANNADM
# MSG91_ROUTE=4

# AWS SNS (Amazon Simple Notification Service)
# Sign up at: https://aws.amazon.com/sns/
# Pricing: $0.00645 per SMS in India
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=ap-south-1
# AWS_SNS_SENDER_ID=Annadanam

# ===== ALTERNATIVE EMAIL PROVIDERS =====

# Mailgun
# Sign up at: https://www.mailgun.com/
# Free tier: 5,000 emails/month for 3 months
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.annadanam.org

# Amazon SES (Simple Email Service)
# Sign up at: https://aws.amazon.com/ses/
# Pricing: $0.10 per 1,000 emails
# AWS_SES_ACCESS_KEY=your_access_key
# AWS_SES_SECRET_KEY=your_secret_key
# AWS_SES_REGION=ap-south-1

# ===== DEVELOPMENT/TESTING =====

# Use mock service for development (no real SMS/email sent)
USE_MOCK_OTP_SERVICE=true

# Log OTPs to console (for testing)
LOG_OTP_TO_CONSOLE=true

# ===== PRODUCTION SETTINGS =====

# OTP expiry time (in minutes)
OTP_EXPIRY_MINUTES=10

# Task OTP expiry time (in hours)
TASK_OTP_EXPIRY_HOURS=24

# Maximum OTP resend attempts per hour
MAX_OTP_RESEND_PER_HOUR=3

# Enable rate limiting
ENABLE_RATE_LIMITING=true
